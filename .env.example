# ─────────────────────────────────────────────
# WHALON 議事録AI — 環境変数定義
# このファイルを .env にコピーして値を設定してください
# .env は絶対にGitにコミットしないこと
# ─────────────────────────────────────────────

# 使用するAIプロバイダー（anthropic / openai / gemini）
AI_PROVIDER=anthropic

# ── Anthropic ──────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ── OpenAI（将来切替用）────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# ── Google Gemini（将来切替用）────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-pro
